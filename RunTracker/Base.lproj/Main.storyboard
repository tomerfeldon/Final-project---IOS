                        <outlet property="paceLabel" destination="pace-label" id="o-active-pace"/>
                        <outlet property="startPauseButton" destination="start-pause-button" id="o-active-start"/>
                        <outlet property="statsStackView" destination="active-stats-stack" id="o-active-stats"/>
                        <outlet property="statusLabel" destination="status-label" id="o-active-status"/>
                        <outlet property="stopButton" destination="stop-button" id="o-active-stop"/>
                        <outlet property="timeLabel" destination="time-label" id="o-active-time"/>
                    </connections>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="active-fr" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="620" y="0.0"/>
        </scene>
        <!--Run Details-->
        <scene sceneID="detail-scene">
            <objects>
                <viewController id="detail-vc" customClass="RunDetailController" customModule="RunTracker" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="detail-view">
