<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="22505" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" initialViewController="nav-controller">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22504"/>
        <capability name="Image references" minToolsVersion="12.0"/>
        <capability name="Named colors" minToolsVersion="9.0"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <!--Navigation Controller-->
        <scene sceneID="nav-scene">
            <objects>
                <navigationController automaticallyAdjustsScrollViewInsets="NO" id="nav-controller" sceneMemberID="viewController">
                    <toolbarItems/>
                    <navigationBar key="navigationBar" contentMode="scaleToFill" insetsLayoutMarginsFromSafeArea="NO" id="nav-bar">
                        <rect key="frame" x="0.0" y="59" width="393" height="44"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </navigationBar>
                    <nil name="viewControllers"/>
                    <connections>
                        <segue destination="list-vc" kind="relationship" relationship="rootViewController" id="nav-root-segue"/>
                    </connections>
                </navigationController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="nav-fr" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="-330" y="0.0"/>
        </scene>
        <!--My Runs-->
        <scene sceneID="list-scene">
            <objects>
                <viewController id="list-vc" customClass="RunsListController" customModule="RunTracker" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="list-view">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <tableView clipsSubviews="YES" contentMode="scaleToFill" alwaysBounceVertical="YES" style="plain" separatorStyle="default" rowHeight="-1" estimatedRowHeight="90" sectionHeaderHeight="18" sectionFooterHeight="18" translatesAutoresizingMaskIntoConstraints="NO" id="runs-table">
                                <rect key="frame" x="0.0" y="103" width="393" height="715"/>
                                <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                                <prototypes>
                                    <tableViewCell clipsSubviews="YES" contentMode="scaleToFill" preservesSuperviewLayoutMargins="YES" selectionStyle="default" indentationWidth="10" reuseIdentifier="RunCell" rowHeight="90" id="run-cell" customClass="RunCell" customModule="RunTracker" customModuleProvider="target">
                                        <rect key="frame" x="0.0" y="0.0" width="393" height="90"/>
                                        <autoresizingMask key="autoresizingMask"/>
                                        <tableViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" preservesSuperviewLayoutMargins="YES" insetsLayoutMarginsFromSafeArea="NO" tableViewCell="run-cell" id="cell-content">
                                            <rect key="frame" x="0.0" y="0.0" width="393" height="90"/>
                                            <autoresizingMask key="autoresizingMask"/>
                                            <subviews>
                                                <stackView opaque="NO" contentMode="scaleToFill" axis="horizontal" alignment="center" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="cell-main-stack">
                                                    <rect key="frame" x="20" y="11" width="353" height="68"/>
                                                    <subviews>
                                                        <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" spacing="6" translatesAutoresizingMaskIntoConstraints="NO" id="cell-info-stack">
                                                            <rect key="frame" x="0.0" y="0.0" width="309" height="68"/>
                                                            <subviews>
                                                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="17 Jul 2026 at 3:07 PM" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cell-date-label">
                                                                    <rect key="frame" x="0.0" y="0.0" width="309" height="21"/>
                                                                    <fontDescription key="fontDescription" style="UICTFontTextStyleHeadline"/>
                                                                    <color key="textColor" systemColor="labelColor"/>
                                                                    <nil key="highlightedColor"/>
                                                                </label>
                                                                <stackView opaque="NO" contentMode="scaleToFill" axis="horizontal" distribution="fillEqually" spacing="8" translatesAutoresizingMaskIntoConstraints="NO" id="cell-stats-stack">
                                                                    <rect key="frame" x="0.0" y="27" width="309" height="41"/>
                                                                    <subviews>
                                                                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="5.2 km" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cell-distance-label">
                                                                            <rect key="frame" x="0.0" y="0.0" width="97.5" height="41"/>
                                                                            <fontDescription key="fontDescription" style="UICTFontTextStyleSubhead"/>
                                                                            <color key="textColor" systemColor="secondaryLabelColor"/>
                                                                            <nil key="highlightedColor"/>
                                                                        </label>
                                                                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="32:15" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cell-duration-label">
                                                                            <rect key="frame" x="105.5" y="0.0" width="97.5" height="41"/>
                                                                            <fontDescription key="fontDescription" style="UICTFontTextStyleSubhead"/>
                                                                            <color key="textColor" systemColor="secondaryLabelColor"/>
                                                                            <nil key="highlightedColor"/>
                                                                        </label>
                                                                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="5:48 /km" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cell-pace-label">
                                                                            <rect key="frame" x="211" y="0.0" width="98" height="41"/>
                                                                            <fontDescription key="fontDescription" style="UICTFontTextStyleSubhead"/>
                                                                            <color key="textColor" systemColor="secondaryLabelColor"/>
                                                                            <nil key="highlightedColor"/>
                                                                        </label>
                                                                    </subviews>
                                                                </stackView>
                                                            </subviews>
                                                        </stackView>
                                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="cell-note-button">
                                                            <rect key="frame" x="321" y="18" width="32" height="32"/>
                                                            <constraints>
                                                                <constraint firstAttribute="width" constant="32" id="c-note-btn-w"/>
                                                                <constraint firstAttribute="height" constant="32" id="c-note-btn-h"/>
                                                            </constraints>
                                                            <state key="normal" image="square.and.pencil" catalog="system"/>
                                                            <connections>
                                                                <action selector="noteButtonTapped:" destination="run-cell" eventType="touchUpInside" id="a-cell-note"/>
                                                            </connections>
                                                        </button>
                                                    </subviews>
                                                </stackView>
                                            </subviews>
                                            <constraints>
                                                <constraint firstItem="cell-main-stack" firstAttribute="leading" secondItem="cell-content" secondAttribute="leadingMargin" id="c-cell-1"/>
                                                <constraint firstItem="cell-main-stack" firstAttribute="top" secondItem="cell-content" secondAttribute="topMargin" id="c-cell-2"/>
                                                <constraint firstAttribute="trailingMargin" secondItem="cell-main-stack" secondAttribute="trailing" id="c-cell-3"/>
                                                <constraint firstAttribute="bottomMargin" secondItem="cell-main-stack" secondAttribute="bottom" id="c-cell-4"/>
                                            </constraints>
                                        </tableViewCellContentView>
                                        <connections>
                                            <outlet property="dateLabel" destination="cell-date-label" id="o-cell-date"/>
                                            <outlet property="distanceLabel" destination="cell-distance-label" id="o-cell-distance"/>
                                            <outlet property="durationLabel" destination="cell-duration-label" id="o-cell-duration"/>
                                            <outlet property="noteButton" destination="cell-note-button" id="o-cell-note-button"/>
                                            <outlet property="paceLabel" destination="cell-pace-label" id="o-cell-pace"/>
                                        </connections>
                                    </tableViewCell>
                                </prototypes>
                            </tableView>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="No runs yet. Tap New Run to record your first one." textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="empty-label">
                                <rect key="frame" x="56" y="411" width="281" height="41"/>
                                <fontDescription key="fontDescription" style="UICTFontTextStyleBody"/>
                                <color key="textColor" systemColor="secondaryLabelColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="list-safe-area"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <constraints>
                            <constraint firstItem="runs-table" firstAttribute="top" secondItem="list-safe-area" secondAttribute="top" id="c-list-1"/>
                            <constraint firstItem="runs-table" firstAttribute="leading" secondItem="list-safe-area" secondAttribute="leading" id="c-list-2"/>
                            <constraint firstItem="list-safe-area" firstAttribute="trailing" secondItem="runs-table" secondAttribute="trailing" id="c-list-3"/>
                            <constraint firstItem="list-safe-area" firstAttribute="bottom" secondItem="runs-table" secondAttribute="bottom" id="c-list-4"/>
                            <constraint firstItem="empty-label" firstAttribute="centerX" secondItem="list-view" secondAttribute="centerX" id="c-list-5"/>
                            <constraint firstItem="empty-label" firstAttribute="centerY" secondItem="list-view" secondAttribute="centerY" id="c-list-6"/>
                            <constraint firstItem="empty-label" firstAttribute="leading" relation="greaterThanOrEqual" secondItem="list-safe-area" secondAttribute="leading" constant="32" id="c-list-7"/>
                            <constraint firstItem="list-safe-area" firstAttribute="trailing" relation="greaterThanOrEqual" secondItem="empty-label" secondAttribute="trailing" constant="32" id="c-list-8"/>
                        </constraints>
                    </view>
                    <navigationItem key="navigationItem" title="My Runs" largeTitleDisplayMode="always" id="list-nav-item">
                        <rightBarButtonItems>
                            <barButtonItem title="New Run" style="plain" id="new-run-item">
                                <connections>
                                    <segue destination="active-vc" kind="show" identifier="showActiveRun" id="segue-new-run"/>
                                </connections>
                            </barButtonItem>
                        </rightBarButtonItems>
                    </navigationItem>
                    <connections>
                        <outlet property="emptyStateLabel" destination="empty-label" id="o-list-empty"/>
                        <outlet property="tableView" destination="runs-table" id="o-list-table"/>
                        <segue destination="detail-vc" kind="show" identifier="showRunDetail" id="segue-detail"/>
                    </connections>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="list-fr" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="140" y="0.0"/>
        </scene>
        <!--Active Run-->
        <scene sceneID="active-scene">
            <objects>
                <viewController id="active-vc" customClass="ActiveRunController" customModule="RunTracker" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="active-view">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" spacing="28" translatesAutoresizingMaskIntoConstraints="NO" id="active-root-stack">
                                <rect key="frame" x="24" y="266" width="345" height="320"/>
                                <subviews>
                                    <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" distribution="fillEqually" spacing="20" translatesAutoresizingMaskIntoConstraints="NO" id="active-stats-stack">
